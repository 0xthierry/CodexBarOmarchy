{
  "name": "codex-bar-omarchy",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "build:shell": "bun build src/shell/main.ts --outfile dist/shell/main.js --target=node --external electron",
    "build:preload": "bun build src/shell/preload.ts --outfile dist/shell/preload.cjs --target=node --format=cjs --external electron",
    "build:ui": "bun build src/ui/main.ts --outfile dist/ui/main.js --target=browser",
    "build:assets": "mkdir -p dist/ui dist/resources && cp src/ui/index.html dist/ui/index.html && cp src/ui/styles.css dist/ui/styles.css && cp resources/tray-icon.png dist/resources/tray-icon.png",
    "build": "bun run build:shell && bun run build:preload && bun run build:ui && bun run build:assets",
    "electron:smoke": "bun run build && electron dist/shell/main.js",
    "format": "oxfmt --write src",
    "format:fix": "oxfmt --write",
    "format:check": "oxfmt --check src",
    "lint": "oxlint src --config oxlint.config.mjs --type-aware --deny-warnings",
    "lint:fix": "oxlint src --config oxlint.config.mjs --type-aware --fix --fix-suggestions --deny-warnings",
    "typecheck": "tsgo --noEmit --project tsconfig.json",
    "start": "bun run build && electron dist/shell/main.js",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "@typescript/native-preview": "7.0.0-dev.20260308.1",
    "electron": "^40.8.0",
    "lefthook": "1.13.6",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "oxlint-tsgolint": "0.16.0"
  },
  "packageManager": "bun@1.3.2"
}
