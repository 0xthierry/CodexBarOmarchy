{
  "name": "agent-stats-omarchy",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "prepare": "lefthook install",
    "build": "bun run typecheck",
    "app": "bun run src/main.ts",
    "build:bin": "bun build --compile src/main.ts --outfile dist/omarchy-agent-bar",
    "package:release": "./scripts/package-release.sh",
    "stats": "bun run app stats",
    "tray": "OMARCHY_AGENT_BAR_ID_SUFFIX=dev bun run app tray",
    "tui": "bun run app tui",
    "format": "oxfmt --write src",
    "format:fix": "oxfmt --write",
    "format:check": "oxfmt --check src",
    "lint": "oxlint src test e2e --config .oxlintrc.json --tsconfig tsconfig.json --report-unused-disable-directives --quiet",
    "lint:fix": "oxlint src test e2e --config .oxlintrc.json --tsconfig tsconfig.json --report-unused-disable-directives --fix --fix-suggestions",
    "lint:fix:files": "oxlint --config .oxlintrc.json --tsconfig tsconfig.json --report-unused-disable-directives --fix --fix-suggestions",
    "lint:strict": "oxlint src test e2e --config .oxlintrc.json --tsconfig tsconfig.json --report-unused-disable-directives",
    "typecheck": "tsgo --noEmit --project tsconfig.json",
    "e2e:host": "bun run e2e/host-integration.ts",
    "e2e:tui": "bun run e2e/tui-smoke.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "@typescript/native-preview": "7.0.0-dev.20260308.1",
    "dbus-next": "^0.10.2",
    "lefthook": "1.13.6",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "oxlint-tsgolint": "0.16.0"
  },
  "packageManager": "bun@1.3.2",
  "dependencies": {
    "@opentui/core": "^0.1.86",
    "x11": "^2.3.0"
  }
}
