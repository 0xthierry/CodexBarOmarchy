{
  "name": "codex-bar-omarchy",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "format": "oxfmt --write src",
    "format:fix": "oxfmt --write",
    "format:check": "oxfmt --check src",
    "lint": "oxlint src --config oxlint.config.mjs --type-aware --deny-warnings",
    "lint:fix": "oxlint src --config oxlint.config.mjs --type-aware --fix --fix-suggestions --deny-warnings",
    "typecheck": "tsgo --noEmit --project tsconfig.json",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "@typescript/native-preview": "7.0.0-dev.20260308.1",
    "lefthook": "1.13.6",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "oxlint-tsgolint": "0.16.0"
  },
  "packageManager": "bun@1.3.2"
}
